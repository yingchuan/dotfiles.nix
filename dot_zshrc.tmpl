# Oh-My-Zsh base directory
export ZSH="$HOME/.oh-my-zsh"

# Theme
ZSH_THEME="bira"

# Plugins
plugins=(
  git
  fzf
  history
  zsh-autosuggestions
  zsh-syntax-highlighting
  ssh-agent
)

# ssh-agent plugin: preload this key
zstyle ':omz:plugins:ssh-agent' identities "$HOME/.ssh/yingchuan"

# Load Oh-My-Zsh
source "$ZSH/oh-my-zsh.sh"

