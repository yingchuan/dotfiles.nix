{ pkgs, ... }:

{
  # Filled automatically by chezmoi
  home.username      = "{{ .chezmoi.username }}";
  home.homeDirectory = "{{ .chezmoi.homeDir }}";

  home.packages = with pkgs; [
    # ── core tools ─────────────────────────
    neovim
    ripgrep
    fd
    bat
    lazygit
    tmux

    # ── language runtimes / compilers ─────
    nodejs_20
    python3
    gcc
  ];

  programs.neovim = {
    enable  = true;
    package = pkgs.neovim;
  };

  # Add more Home-Manager options below when needed

  # Required by Home-Manager ≥ 22.05
  # First Home-Manager version when this profile was created.
  # Lower is OK, but never raise it once set.
  home.stateVersion = "23.11";
}
