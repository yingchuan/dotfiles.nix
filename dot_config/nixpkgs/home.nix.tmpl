{ pkgs, ... }:

{
  # Filled automatically by chezmoi
  home.username      = "{{ .chezmoi.username }}";
  home.homeDirectory = "{{ .chezmoi.homeDir }}";

  home.packages = with pkgs; [
    # ── core tools ─────────────────────────
    neovim
    ripgrep
    fd
    bat
    lazygit

    # ── language runtimes / compilers ─────
    nodejs_20
    python3
    gcc
  ];

  programs.neovim = {
    enable  = true;
    package = pkgs.neovim;
  };

  # Add more Home-Manager options below when needed
}
